# Database — Supabase Postgres via asyncpg
# Format: postgresql+asyncpg://user:password@host:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@db.bpzcogoixzxlzaaijdcr.supabase.co:5432/postgres

# OpenAI
OPENAI_API_KEY=sk-...

# Internal auth — static bearer token for calls from the Edge Function proxy
SERVICE_API_KEY=change-me-in-production

# Webhook auth — must match the x-webhook-secret header configured in Supabase Dashboard
WEBHOOK_SECRET=change-me-in-production

# Worker tuning
POLL_INTERVAL_SECONDS=5
WORKER_CONCURRENCY=4

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
